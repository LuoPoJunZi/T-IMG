# Required for uploads and Telegram-hosted file access.
TG_Bot_Token=your_telegram_bot_token
TG_Chat_ID=your_telegram_chat_id

# Optional. Defaults to 20 MiB and cannot exceed that retrievable limit.
MAX_UPLOAD_SIZE_BYTES=20971520

# Strongly recommended when the management API is enabled.
BASIC_USER=your_admin_username
BASIC_PASS=your_strong_admin_password

# Optional content moderation and whitelist mode.
ModerateContentApiKey=your_api_key
WhiteList_Mode=false

# img_url is a Cloudflare KV namespace binding, not a string environment value.
